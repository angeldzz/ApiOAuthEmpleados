@model Empleado

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-4 rounded-top-4">
                    <h2 class="mb-0">Perfil de Empleado</h2>
                    <p class="mb-0 text-light">ID: @Model.IdEmpleado</p>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">Apellido</div>
                        <div class="col-sm-8 fs-5">@Model.Apellido</div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">Oficio</div>
                        <div class="col-sm-8 fs-5">@Model.Oficio</div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">Salario</div>
                        <div class="col-sm-8 fs-5 text-success fw-bold">@Model.Salario.ToString("C")</div>
                    </div>
                    <hr>
                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted fw-bold">Departamento</div>
                        <div class="col-sm-8 fs-5">@Model.IdDepartamento</div>
                    </div>
                </div>
                <div class="card-footer text-center bg-light py-3 rounded-bottom-4">
                    <a asp-action="Index" class="btn btn-outline-primary px-4 rounded-pill">Volver</a>
                </div>
            </div>
        </div>
    </div>
</div>
